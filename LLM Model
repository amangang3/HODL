I_API_KEY\"] = userdata.get('OPENAI_API_KEY')\n","\n","# Initialize the OpenAI client\n","client = OpenAI()\n","\n","def get_prediction_with_usage(text):\n","    \"\"\"Utility function to classify news and return token usage\"\"\"\n","    response = client.chat.completions.create(\n","        model=\"gpt-4o-mini\",\n","        messages=[\n","            {\"role\": \"system\", \"content\": \"You are a fact-checking assistant. Classify the following news as 'True' or 'Fake'. Respond with only the word 'True' or 'Fake'.\"},\n","            {\"role\": \"user\", \"content\": f\"News: {text}\"}\n","        ],\n","        max_tokens=5\n","    )\n","    content = response.choices[0].message.content.strip()\n","    usage = response.usage\n","    return content, usage.prompt_tokens, usage.completion_tokens\n","\n","print(\"OpenAI Client updated to track token usage.\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["OpenAI Client updated to track token usage.\n"]}]},{"cell_type":"code","source":["import os, json, hashlib\n","import pandas as pd\n","from pathlib import Path\n","\n","# --------- CONFIG ----------\n","TEXT_COL = \"text\"          # the column you feed to the LLM\n","TRUTH_COL = \"truth\"        # ground-truth label (must NOT be sent to LLM)\n","ID_COL = \"row_id\"\n","CHUNK_COL = \"chunk_id\"\n","N_CHUNKS = 4\n","\n","# (Optional) if you also have title/subject and want IDs to be more robust:\n","EXTRA_ID_COLS = [c for c in [\"title\", \"subject\", \"date\"] if c in test_df.columns]\n","\n","def make_stable_row_id(row: pd.Series) -> str:\n","    \"\"\"\n","    Stable ID derived from content (reshuffle-proof).\n","    Uses text + optional extra columns (title/subject/date) if present.\n","    \"\"\"\n","    parts = [str(row.get(TEXT_COL, \"\"))]\n","    for c in EXTRA_ID_COLS:\n","        parts.append(str(row.get(c, \"\")))\n","    key = \"\\u241f\".join(parts)  # unlikely separator\n","    return hashlib.sha1(key.encode(\"utf-8\", errors=\"ignore\")).hexdigest()\n","\n","# 1) Ensure we don't modify your original df unintentionally\n","test_df = test_df.copy()\n","\n","# 2) Assign stable IDs if missing\n","if ID_COL not in test_df.columns:\n","    test_df[ID_COL] = test_df.apply(make_stable_row_id, axis=1)\n","\n","# 3) Deterministically assign each row to one of 4 chunks (reshuffle-proof)\n","def chunk_from_id(hex_id: str, n_chunks: int = N_CHUNKS) -> int:\n","    # take first 8 hex chars -> int, mod n_chunks\n","    return int(hex_id[:8], 16) % n_chunks\n","\n","test_df[CHUNK_COL] = test_df[ID_COL].apply(lambda x: chunk_from_id(x, N_CHUNKS))\n","\n","# Quick sanity check\n","print(test_df[[ID_COL, CHUNK_COL]].head())\n","print(\"Chunk sizes:\", test_df[CHUNK_COL].value_counts().sort_index().to_dict())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"alemrob_2mvp","executionInfo":{"status":"ok","timestamp":1773495171279,"user_tz":240,"elapsed":411,"user":{"displayName":"Yiwei Wang","userId":"13953772695009695674"}},"outputId":"1e0d3d69-63c2-41f7-8748-ef956a9fd3d8"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["                                         row_id  chunk_id\n","22216  831cf1146f4968eb3b9902953cf67ca4f315b765         0\n","27917  c65b159df09cad712988a9e38f52f1bda1ca33f5         1\n","25007  b6bc3eb4d1ad08c694a4f66c41e54327029f7ee4         0\n","1377   62a13ecf0d9e599cc66cd63e46fa51f7c7e05fd6         3\n","32476  f2cdfbac85641cd84ec8106a3997ee9e88b186b5         0\n","Chunk sizes: {0: 3333, 1: 3313, 2: 3356, 3: 3468}\n"]}]},{"cell_type":"code","source":["from tqdm import tqdm\n","\n","def load_done_ids(checkpoint_path: str) -> set[str]:\n","    done = set()\n","    ckpt = Path(checkpoint_path)\n","    if not ckpt.exists():\n","        return done\n","    with ckpt.open(\"r\", encoding=\"utf-8\") as f:\n","        for line in f:\n","            line = line.strip()\n","            if not line:\n","                continue\n","            try:\n","                obj = json.loads(line)\n","                rid = obj.get(ID_COL)\n","                if rid:\n","                    done.add(rid)\n","            except json.JSONDecodeError:\n","                # ignore partial/corrupt lines\n","                continue\n","    return done\n","\n","def append_ckpt(checkpoint_path: str, obj: dict):\n","    ckpt = Path(checkpoint_path)\n","    ckpt.parent.mkdir(parents=True, exist_ok=True)\n","    with ckpt.open(\"a\", encoding=\"utf-8\") as f:\n","        f.write(json.dumps(obj, ensure_ascii=False) + \"\\n\")\n","        f.flush()\n","        os.fsync(f.fileno())\n","\n","def evaluate_dataset_batch(\n","    df: pd.DataFrame,\n","    checkpoint_path: str,\n","    text_col: str = TEXT_COL,\n","    id_col: str = ID_COL,\n","    stop_on_rate_limit: bool = True,\n","):\n","    \"\"\"\n","    Processes df row-by-row with append-only JSONL checkpointing.\n","    Skips rows already present in checkpoint (by stable row_id).\n","\n","    IMPORTANT:\n","    - Only uses df[text_col] (and optionally other non-truth cols you add) for the LLM prompt.\n","    - NEVER reads or sends df[TRUTH_COL] to the LLM.\n","    \"\"\"\n","    done_ids = load_done_ids(checkpoint_path)\n","\n","    results_this_run = []\n","    total_prompt_tokens = 0\n","    total_completion_tokens = 0\n","\n","    # filter to unprocessed\n","    df_todo = df[~df[id_col].isin(done_ids)].copy()\n","\n","    print(f\"Checkpoint: {checkpoint_path}\")\n","    print(f\"Already done: {len(done_ids)} | Remaining in this chunk: {len(df_todo)}\")\n","\n","    for _, row in tqdm(df_todo.iterrows(), total=len(df_todo)):\n","        row_id = row[id_col]\n","\n","        # --- Build LLM input WITHOUT truth ---\n","        article_text = row[text_col]\n","\n","        try:\n","            # You should already have something like this from your previous code:\n","            # pred_text, p_tokens, c_tokens = get_prediction_with_usage(article_text)\n","            pred_text, p_tokens, c_tokens = get_prediction_with_usage(article_text)\n","\n","            total_prompt_tokens += int(p_tokens or 0)\n","            total_completion_tokens += int(c_tokens or 0)\n","\n","            record = {\n","                id_col: row_id,\n","                \"pred_text\": str(pred_text),\n","                \"prompt_tokens\": int(p_tokens or 0),\n","                \"completion_tokens\": int(c_tokens or 0),\n","            }\n","            append_ckpt(checkpoint_path, record)\n","            results_this_run.append(record)\n","\n","        except Exception as e:\n","            msg = str(e).lower()\n","\n","            # If you want to stop immediately on rate limit/quota errors:\n","            if stop_on_rate_limit and (\"rate limit\" in msg or \"quota\" in msg or \"429\" in msg):\n","                print(\"Hit rate limit/quota; stopping so you can resume later.\")\n","                break\n","\n","            # otherwise log error and continue\n","            err_record = {id_col: row_id, \"error\": str(e)}\n","            append_ckpt(checkpoint_path, err_record)\n","            results_this_run.append(err_record)\n","\n","    return results_this_run, total_prompt_tokens, total_completion_tokens"],"metadata":{"id":"VlwBm2Yv2n6-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["chunk_id = 0\n","chunk_df = test_df[test_df[\"chunk_id\"] == chunk_id].copy()\n","\n","# Per-chunk checkpoint file (recommended)\n","ckpt_path = f\"checkpoints/test_chunk_{chunk_id}.jsonl\"\n","\n","chunk_results, p_tok, c_tok = evaluate_dataset_batch(\n","    chunk_df,\n","    checkpoint_path=ckpt_path,\n",")\n","\n","print(\"This run processed:\", len(chunk_results))\n","print(\"Prompt tokens this run:\", p_tok)\n","print(\"Completion tokens this run:\", c_tok)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PiZvesh92pte","executionInfo":{"status":"ok","timestamp":1773241027395,"user_tz":240,"elapsed":1792845,"use